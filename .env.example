# Template for the server's environment. Copy to .env next to
# docker-compose.server.yml and fill in GITHUB_TOKEN:
#
#     cp .env.example .env
#
# .env is gitignored, so your token never gets committed.

# REQUIRED. Fine-grained personal access token with Contents: read and write on
# BeefMediumRare/JomezPro-Track-Generator. This is the only credential that can
# push tracks, so keep it scoped to just this repo.
GITHUB_TOKEN=github_pat_REPLACE_ME

# --- Optional overrides (defaults shown; uncomment to change) ---

# How often the server scans for new videos, in seconds.
#SCAN_INTERVAL_SEC=3600

# Ignore videos older than this many days. Bump it for a one-off back-fill.
#MAX_AGE_DAYS=1

# How many of the newest uploads to look at per scan.
#MAX_SCAN_ENTRIES=50

# Identity for the (unsigned) commits the server pushes.
#GIT_USER_NAME=jomez-track-bot
#GIT_USER_EMAIL=jomez-track-bot@users.noreply.github.com
